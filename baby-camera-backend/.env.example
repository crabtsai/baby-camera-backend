# =========================================================
# Baby Camera Backend Example Config
# 複製成 .env 後再依照你的環境修改
# =========================================================

APP_NAME=Baby Camera Backend
APP_HOST=0.0.0.0
APP_PORT=8000

# 攝影機來源：
# 0 = 本機 USB Camera
# rtsp://xxx = IP Camera / MediaMTX
# http://xxx/video = MJPEG Stream
# data/videos/test.mp4 = 測試影片
CAMERA_ID=baby-cam-01
CAMERA_SOURCE=0

# 抽幀頻率：AI 偵測不需要 30 FPS，通常 1 秒 1 張即可
FRAME_INTERVAL_SEC=1.0

# 串流輸出 JPEG 品質
STREAM_JPEG_QUALITY=80

# 資料庫與資料夾
DATABASE_PATH=data/baby_camera.db
SNAPSHOT_DIR=data/snapshots
LOG_DIR=logs

# 畫面太暗偵測
ENABLE_DARK_DETECTOR=true
DARK_BRIGHTNESS_THRESHOLD=30
DARK_DURATION_SEC=10
DARK_COOLDOWN_SEC=300

# 長時間低動作提醒
ENABLE_MOTION_DETECTOR=true
MOTION_DIFF_THRESHOLD=8
MOTION_LOW_RATIO_THRESHOLD=0.003
MOTION_DURATION_SEC=60
MOTION_COOLDOWN_SEC=600

# 預留：寶寶位置偵測 / 臉部遮蔽偵測
ENABLE_BABY_DETECTOR=false
ENABLE_FACE_COVER_DETECTOR=false

# 告警 Webhook：建議填你的 Firebase Cloud Function URL
# Python 偵測到異常 → 呼叫這個 URL → Cloud Function → Firestore / LINE
ALERT_WEBHOOK_URL= "https://ingestalert-qffjkcl3ea-de.a.run.app"
ALERT_INGEST_KEY= 'baby123'
ALERT_TIMEOUT_SEC=5

# 開發測試用：true 時不真的打 webhook，只寫 log
ALERT_DRY_RUN=false
